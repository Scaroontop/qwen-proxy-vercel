{
  "rewrites": [
    { "source": "/v1/chat/completions", "destination": "/api/chat" },
    { "source": "/chat/completions", "destination": "/api/chat" },
    { "source": "/v1/models", "destination": "/api/models" },
    { "source": "/models", "destination": "/api/models" },
    { "source": "/api/tokens/:path*", "destination": "/api/tokens" },
    { "source": "/api/tokens", "destination": "/api/tokens" },
    { "source": "/health", "destination": "/api/health" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Headers", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,DELETE,OPTIONS" }
      ]
    }
  ],
  "functions": {
    "api/chat.py": {
      "maxDuration": 60
    }
  }
}
